{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tachyon Beta",
  "version": "0.1.5-beta",
  "identifier": "com.ayush18.tachyon-beta",
  "build": {
    "beforeDevCommand": "sh ui/build-web.sh",
    "beforeBuildCommand": "sh ui/build-web.sh",
    "frontendDist": "../ui/target/dx/tachyon-ui/debug/web/public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tachyon Beta",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
